# Supabase — same instance as hdpm-web
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose client-side

# Microsoft Entra ID (Azure AD) — add redirect URI for this app in your Azure app registration
# Supabase handles OAuth; these are set in Supabase dashboard under Auth > Providers > Azure
# AZURE_CLIENT_ID and AZURE_CLIENT_SECRET live in Supabase, not here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron — protects sync endpoints from unauthorized access
CRON_SECRET=your-cron-secret

# AppFolio API — basic auth with client credentials
APPFOLIO_SUBDOMAIN=your-subdomain
APPFOLIO_CLIENT_ID=your-appfolio-client-id
APPFOLIO_CLIENT_SECRET=your-appfolio-client-secret

# PropertyMeld API
PROPERTYMELD_API_KEY=your-propertymeld-api-key
PROPERTYMELD_ORG_ID=your-propertymeld-org-id

# QuickBooks Online API — OAuth 2.0
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
QUICKBOOKS_REALM_ID=your-quickbooks-company-id
QUICKBOOKS_REFRESH_TOKEN=your-quickbooks-refresh-token
